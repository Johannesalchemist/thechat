<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book Room — Nyxa</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:      #04040f;
      --surface: rgba(10,10,22,0.95);
      --border:  rgba(255,255,255,0.07);
      --text:    #e8e8f4;
      --muted:   #5a5a7a;
      --radius:  10px;
    }

    html, body {
      height: 100%;
      background: var(--bg);
      color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 14px;
      line-height: 1.6;
      overflow: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      width: 700px; height: 700px;
      border-radius: 50%;
      background: rgba(124,58,237,0.06);
      top: -250px; left: -150px;
      filter: blur(90px);
      pointer-events: none; z-index: 0;
      animation: amb1 24s ease-in-out infinite alternate;
    }
    @keyframes amb1 { to { transform: translate(70px, 90px); } }

    #shell {
      display: grid;
      grid-template-columns: 220px 1fr 220px;
      grid-template-rows: 48px 1fr;
      height: 100vh;
      position: relative; z-index: 1;
    }

    /* ── Header ── */
    header {
      grid-column: 1 / -1;
      display: flex; align-items: center; gap: 16px;
      padding: 0 18px;
      background: rgba(4,4,15,0.88);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(20px);
    }
    .logo-back {
      display: flex; align-items: center; gap: 8px;
      text-decoration: none; color: var(--muted);
      font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase;
      transition: color 0.2s;
    }
    .logo-back:hover { color: var(--text); }
    .logo-sep { color: var(--border); margin: 0 2px; }
    .header-title {
      font-size: 12px; font-weight: 700; letter-spacing: 0.18em;
      text-transform: uppercase;
      background: linear-gradient(90deg, #a78bfa, #34d399);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* ── Stability bar ── */
    #stability-wrap {
      margin-left: auto; display: flex; align-items: center; gap: 8px;
    }
    #stability-label {
      font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--muted);
    }
    #stability-track {
      width: 120px; height: 3px;
      background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden;
    }
    #stability-fill {
      height: 100%; border-radius: 2px;
      transition: width 0.8s ease, background 0.8s ease;
    }
    #stability-pct {
      font-size: 10px; font-variant-numeric: tabular-nums; min-width: 30px;
    }

    /* ── Columns ── */
    .col {
      overflow: hidden; display: flex; flex-direction: column; gap: 8px;
      padding: 10px 8px;
    }
    .col-left  { border-right: 1px solid var(--border); }
    .col-right { border-left:  1px solid var(--border); }

    /* ── Cards ── */
    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 10px 12px;
    }
    .card-title {
      font-size: 8px; letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--muted); margin-bottom: 8px;
    }

    /* ── Book title input ── */
    #book-title-input {
      width: 100%;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 6px; padding: 6px 9px;
      color: var(--text); font-size: 13px;
      outline: none; transition: border-color 0.2s;
    }
    #book-title-input:focus { border-color: rgba(167,139,250,0.4); }

    /* ── Chapter list ── */
    #chapters-list { overflow-y: auto; flex: 1; }
    .chapter-item {
      padding: 6px 8px; border-radius: 6px; cursor: pointer;
      color: var(--muted); font-size: 12px;
      transition: all 0.15s;
    }
    .chapter-item:hover { background: rgba(255,255,255,0.04); color: var(--text); }
    .chapter-item.active { background: rgba(167,139,250,0.12); color: #c4b5fd; }

    /* ── Main column ── */
    #main { padding: 10px 12px; }
    #main .col { padding: 0; gap: 10px; }

    /* ── Chapter editor ── */
    #chapter-editor {
      display: none; /* shown when a chapter is selected */
    }
    #chapter-editor.on { display: block; }
    #chapter-editor-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 8px;
    }
    #chapter-editor-title {
      font-size: 9px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted);
    }
    #chapter-editor-close {
      background: none; border: none; cursor: pointer;
      color: var(--muted); font-size: 14px; padding: 0; line-height: 1;
      transition: color 0.2s;
    }
    #chapter-editor-close:hover { color: var(--text); }
    #chapter-editor textarea {
      width: 100%;
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);
      border-radius: 7px; padding: 9px 11px;
      color: var(--text); font-size: 13px; line-height: 1.7;
      resize: none; outline: none; min-height: 90px;
      font-family: 'Georgia', serif;
      transition: border-color 0.2s;
    }
    #chapter-editor textarea:focus { border-color: rgba(167,139,250,0.3); }

    /* ── Chat ── */
    #chat-card { flex: 1; display: flex; flex-direction: column; overflow: hidden; }
    #chat-messages {
      flex: 1; overflow-y: auto; padding: 4px 2px;
      display: flex; flex-direction: column; gap: 8px;
    }
    .bubble {
      padding: 9px 12px; border-radius: 9px;
      animation: bubble-in 0.3s ease;
    }
    @keyframes bubble-in { from { opacity:0; transform: translateY(6px); } to { opacity:1; transform: translateY(0); } }
    .bubble-user { background: rgba(255,255,255,0.05); margin-left: 32px; }
    .bubble-agent { background: rgba(10,10,30,0.6); border: 1px solid rgba(255,255,255,0.06); }
    .bubble-system { background: none; padding: 4px 2px; }
    .bubble-sender {
      font-size: 9px; letter-spacing: 0.16em; text-transform: uppercase;
      margin-bottom: 3px; font-weight: 600;
    }
    .bubble-text { font-size: 13px; line-height: 1.72; color: rgba(232,232,244,0.88); }
    .bubble-system .bubble-text { color: rgba(255,255,255,0.25); font-size: 11px; font-style: italic; }
    .thinking { color: var(--muted); font-size: 11px; font-style: italic; padding: 4px 2px; }

    /* ── Chat input ── */
    #chat-input-row {
      display: flex; gap: 8px; padding-top: 8px;
      border-top: 1px solid var(--border);
    }
    #chat-input {
      flex: 1;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);
      border-radius: 7px; padding: 7px 10px;
      color: var(--text); font-size: 13px; resize: none;
      outline: none; min-height: 36px; max-height: 72px;
      font-family: 'Segoe UI', system-ui, sans-serif;
      transition: border-color 0.2s;
    }
    #chat-input:focus { border-color: rgba(167,139,250,0.3); }
    #chat-send {
      padding: 7px 16px; border-radius: 7px;
      background: rgba(167,139,250,0.14); border: 1px solid rgba(167,139,250,0.25);
      color: #c4b5fd; font-size: 11px; letter-spacing: 0.12em; cursor: pointer;
      transition: all 0.2s; white-space: nowrap; align-self: flex-end;
    }
    #chat-send:hover:not(:disabled) { background: rgba(167,139,250,0.25); }
    #chat-send:disabled { opacity: 0.35; cursor: default; }

    /* ── Agent toggles ── */
    .agent-toggle {
      display: flex; align-items: center; gap: 8px;
      padding: 7px 9px; border-radius: 7px; cursor: pointer;
      transition: all 0.15s; font-size: 12px;
      border: 1px solid transparent;
    }
    .agent-toggle.off { opacity: 0.3; }
    .agent-toggle.on { border-color: rgba(255,255,255,0.07); background: rgba(255,255,255,0.03); }
    .agent-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
    .agent-on-badge { margin-left: auto; font-size: 8px; color: var(--muted); letter-spacing: 0.1em; }

    /* ── Action buttons ── */
    .action-btn {
      width: 100%; text-align: left; padding: 8px 10px; border-radius: 7px;
      background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.07);
      color: rgba(232,232,244,0.7); font-size: 11px; letter-spacing: 0.08em;
      cursor: pointer; transition: all 0.2s;
    }
    .action-btn:hover:not(:disabled) {
      background: rgba(255,255,255,0.08); color: var(--text);
    }
    .action-btn:disabled { opacity: 0.35; cursor: default; }
    .action-btn.publish-done { background: rgba(52,211,153,0.12); color: #6ee7b7; border-color: rgba(52,211,153,0.2); }
    .action-btn.publish-exporting { background: rgba(251,191,36,0.1); color: #fcd34d; border-color: rgba(251,191,36,0.2); }

    /* ── Stats ── */
    .stat-row {
      display: flex; justify-content: space-between;
      font-size: 11px; color: var(--muted); padding: 2px 0;
    }
    .stat-val { color: rgba(232,232,244,0.6); }

    /* ── Scrollbar ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 2px; }

    /* ── Book Room entry point in room.html (not here, but link back) ── */
    #back-to-room {
      margin-left: auto;
      font-size: 10px; letter-spacing: 0.14em; color: var(--muted);
      text-decoration: none; transition: color 0.2s;
    }
    #back-to-room:hover { color: var(--text); }
  </style>
</head>
<body>
<div id="shell">

  <!-- Header -->
  <header>
    <a href="/dashboard/room.html" class="logo-back">← The Room</a>
    <span class="logo-sep">|</span>
    <span class="header-title">Book Room</span>
    <div id="stability-wrap">
      <span id="stability-label">Stability</span>
      <div id="stability-track"><div id="stability-fill"></div></div>
      <span id="stability-pct"></span>
    </div>
  </header>

  <!-- Left: Book + Chapters -->
  <div class="col col-left">
    <div class="card">
      <div class="card-title">Book</div>
      <input id="book-title-input" value="Untitled Book" placeholder="Untitled Book" />
    </div>
    <div class="card" style="flex:1; overflow:hidden; display:flex; flex-direction:column;">
      <div class="card-title">Chapters</div>
      <div id="chapters-list" style="flex:1; overflow-y:auto;"></div>
    </div>
  </div>

  <!-- Center: Chat + chapter editor -->
  <div class="col" id="main" style="overflow:hidden; display:flex; flex-direction:column; gap:10px; padding:10px 12px;">

    <!-- Chapter editor (hidden until chapter selected) -->
    <div id="chapter-editor" class="card">
      <div id="chapter-editor-header">
        <span id="chapter-editor-title">Chapter</span>
        <button id="chapter-editor-close">✕</button>
      </div>
      <textarea id="chapter-editor-text" rows="4" placeholder="Write here — agents are watching…"></textarea>
    </div>

    <!-- Chat card -->
    <div class="card" id="chat-card">
      <div id="chat-messages"></div>
      <div id="chat-input-row">
        <textarea id="chat-input" rows="1" placeholder="Talk to agents or share your idea…"></textarea>
        <button id="chat-send">Send</button>
      </div>
    </div>
  </div>

  <!-- Right: Agents + Actions + Stats -->
  <div class="col col-right">
    <div class="card">
      <div class="card-title">Agents</div>
      <div id="agents-panel"></div>
    </div>
    <div class="card">
      <div class="card-title">Actions</div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        <button class="action-btn" id="btn-generate">Generate Chapter</button>
        <button class="action-btn" id="btn-critique">Run Critique</button>
        <button class="action-btn" id="btn-synthesize">Synthesize</button>
        <button class="action-btn" id="btn-publish">Publish</button>
      </div>
    </div>
    <div class="card">
      <div class="card-title">Manuscript</div>
      <div id="stats-panel">
        <div class="stat-row"><span>Chapters</span><span class="stat-val" id="stat-chapters">0</span></div>
        <div class="stat-row"><span>Words</span><span class="stat-val" id="stat-words">0</span></div>
        <div class="stat-row"><span>Agent turns</span><span class="stat-val" id="stat-turns">0</span></div>
        <div class="stat-row"><span>Active agents</span><span class="stat-val" id="stat-active">0</span></div>
        <div class="stat-row" style="margin-top:6px;border-top:1px solid rgba(255,255,255,0.05);padding-top:6px;">
          <span>State</span><span class="stat-val" id="stat-state">DRAFT</span>
        </div>
        <div class="stat-row"><span>Loops</span><span class="stat-val" id="stat-loops">0</span></div>
      </div>
    </div>
  </div>

</div>

<script>
// ── State ────────────────────────────────────────────────────────────────────
const AGENTS = {
  Muse:      { color: '#a78bfa', role: 'emotional resonance, imagery, tone' },
  Alchemist: { color: '#34d399', role: 'transformation, structure, depth' },
  Sage:      { color: '#60a5fa', role: 'clarity, wisdom, argument' },
  Critic:    { color: '#f87171', role: 'weakness, contradiction, what\'s missing' },
};

let bookTitle    = 'Untitled Book';
let chapters     = [
  { id: 1, title: 'Chapter 1', content: '' },
  { id: 2, title: 'Chapter 2', content: '' },
  { id: 3, title: 'Chapter 3', content: '' },
];
let activeChapter = null;
let activeAgents  = new Set(['Muse', 'Sage']);
let stability     = 0;
let busy          = false;
let publishState  = null; // null | 'exporting' | 'done'
let messages      = [];
let agentTurns    = 0;
let msgId         = 0;
let loopCount     = 0;
let bookState     = 'DRAFT';

const uid     = localStorage.getItem('nyxa_uid') || (() => {
  const id = 'u' + Date.now().toString(36);
  localStorage.setItem('nyxa_uid', id); return id;
})();
const userId  = 'book_' + uid;
const bookId  = 'book_' + uid;

// ── DOM refs ─────────────────────────────────────────────────────────────────
const $chatMessages   = document.getElementById('chat-messages');
const $chatInput      = document.getElementById('chat-input');
const $chatSend       = document.getElementById('chat-send');
const $chaptersList   = document.getElementById('chapters-list');
const $titleInput     = document.getElementById('book-title-input');
const $agentsPanel    = document.getElementById('agents-panel');
const $chapterEditor  = document.getElementById('chapter-editor');
const $editorTitle    = document.getElementById('chapter-editor-title');
const $editorText     = document.getElementById('chapter-editor-text');
const $editorClose    = document.getElementById('chapter-editor-close');
const $stabilityFill  = document.getElementById('stability-fill');
const $stabilityPct   = document.getElementById('stability-pct');
const $btnGenerate    = document.getElementById('btn-generate');
const $btnCritique    = document.getElementById('btn-critique');
const $btnSynthesize  = document.getElementById('btn-synthesize');
const $btnPublish     = document.getElementById('btn-publish');

// ── Stability ────────────────────────────────────────────────────────────────
function nudgeStability(delta) {
  stability = Math.min(100, Math.max(0, stability + delta));
  renderStability();
}

function renderStability() {
  const color = stability < 35 ? '#f87171' : stability < 65 ? '#fbbf24' : '#34d399';
  $stabilityFill.style.width    = stability + '%';
  $stabilityFill.style.background = color;
  $stabilityPct.style.color     = color;
  $stabilityPct.textContent     = stability + '%';
}

// ── Messages ─────────────────────────────────────────────────────────────────
function addMessage(sender, text, streaming = false) {
  const id = ++msgId;
  const isUser   = sender === 'User';
  const isSystem = sender === 'System';
  const color    = AGENTS[sender]?.color || '#9ca3af';

  const div = document.createElement('div');
  div.className = 'bubble ' + (isUser ? 'bubble-user' : isSystem ? 'bubble-system' : 'bubble-agent');
  div.dataset.id = id;

  if (!isSystem) {
    const senderEl = document.createElement('div');
    senderEl.className = 'bubble-sender';
    senderEl.style.color = isUser ? 'rgba(255,255,255,0.35)' : color;
    senderEl.textContent = sender;
    div.appendChild(senderEl);
  }

  const textEl = document.createElement('div');
  textEl.className = 'bubble-text';
  div.appendChild(textEl);
  $chatMessages.appendChild(div);
  $chatMessages.scrollTop = $chatMessages.scrollHeight;

  if (!isAgent(sender)) {
    textEl.textContent = text;
  } else {
    // Stream character by character
    agentTurns++;
    let i = 0;
    const speed = 14;
    const interval = setInterval(() => {
      i++;
      textEl.textContent = text.slice(0, i) + (i < text.length ? '▍' : '');
      $chatMessages.scrollTop = $chatMessages.scrollHeight;
      if (i >= text.length) clearInterval(interval);
    }, speed);
  }

  updateStats();
  return id;
}

function isAgent(sender) {
  return !!AGENTS[sender];
}

function showThinking(show) {
  let el = document.getElementById('thinking-indicator');
  if (show && !el) {
    el = document.createElement('div');
    el.id = 'thinking-indicator';
    el.className = 'thinking';
    el.textContent = 'agents thinking…';
    $chatMessages.appendChild(el);
    $chatMessages.scrollTop = $chatMessages.scrollHeight;
  } else if (!show && el) {
    el.remove();
  }
}

// ── Chapters ─────────────────────────────────────────────────────────────────
function renderChapters() {
  $chaptersList.innerHTML = '';
  chapters.forEach(ch => {
    const li = document.createElement('div');
    li.className = 'chapter-item' + (activeChapter?.id === ch.id ? ' active' : '');
    li.textContent = ch.title;
    li.onclick = () => selectChapter(activeChapter?.id === ch.id ? null : ch);
    $chaptersList.appendChild(li);
  });
}

function selectChapter(ch) {
  activeChapter = ch;
  renderChapters();
  if (ch) {
    $chapterEditor.classList.add('on');
    $editorTitle.textContent = ch.title;
    $editorText.value = ch.content || '';
  } else {
    $chapterEditor.classList.remove('on');
  }
}

$editorClose.onclick = () => selectChapter(null);

$editorText.addEventListener('input', () => {
  if (!activeChapter) return;
  activeChapter.content = $editorText.value;
  chapters = chapters.map(c => c.id === activeChapter.id ? activeChapter : c);
  updateStats();
  saveBook();
});

// ── Agents panel ─────────────────────────────────────────────────────────────
function renderAgents() {
  $agentsPanel.innerHTML = '';
  Object.entries(AGENTS).forEach(([name, { color, role }]) => {
    const on = activeAgents.has(name);
    const div = document.createElement('div');
    div.className = 'agent-toggle ' + (on ? 'on' : 'off');
    div.title = role;
    div.innerHTML = `<span class="agent-dot" style="background:${color}"></span>
      <span>${name}</span>
      ${on ? '<span class="agent-on-badge">on</span>' : ''}`;
    div.onclick = () => {
      on ? activeAgents.delete(name) : activeAgents.add(name);
      renderAgents();
      updateStats();
    };
    $agentsPanel.appendChild(div);
  });
}

// ── Stats ─────────────────────────────────────────────────────────────────────
function updateStats() {
  document.getElementById('stat-chapters').textContent = chapters.length;
  const words = chapters.reduce((s, c) => s + (c.content?.split(/\s+/).filter(Boolean).length || 0), 0);
  document.getElementById('stat-words').textContent = words;
  document.getElementById('stat-turns').textContent = agentTurns;
  document.getElementById('stat-active').textContent = activeAgents.size;
  document.getElementById('stat-state').textContent = bookState;
  document.getElementById('stat-loops').textContent = loopCount;
}

// ── API calls ─────────────────────────────────────────────────────────────────
async function callAgent(agent, prompt, context = '') {
  const r = await fetch('/api/book/agent', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ agent, prompt, context, bookTitle })
  });
  if (!r.ok) throw new Error('agent call failed');
  const data = await r.json();
  return data.reply;
}

async function orchestrate(userMessage) {
  const context = activeChapter?.content || chapters[chapters.length - 1]?.content || '';
  const r = await fetch('/api/book/orchestrate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      bookId, userMessage, chapterContent: context,
      activeAgents: [...activeAgents], stability
    })
  });
  if (!r.ok) throw new Error('orchestrate failed');
  return r.json();
}

async function synthesizeChapter() {
  const agentOutputs = {};
  const context = activeChapter?.content || '';
  for (const agent of activeAgents) {
    try { agentOutputs[agent] = await callAgent(agent, 'Review the current chapter. What needs synthesis?', context); }
    catch {}
  }
  const r = await fetch('/api/book/synthesize', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ bookId, agentOutputs, chapterContent: context })
  });
  if (!r.ok) throw new Error('synthesis failed');
  return r.json();
}

async function generateChapterAPI(chapterIndex) {
  const r = await fetch('/api/book/chapter/generate', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ bookTitle, chapterIndex, existingChapters: chapters, userId })
  });
  if (!r.ok) throw new Error('chapter generation failed');
  const data = await r.json();
  return data.content;
}

// ── Book persistence ──────────────────────────────────────────────────────────
async function saveBook() {
  try {
    await fetch('/api/book/' + userId, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookTitle, chapters })
    });
  } catch {}
}

async function loadBook() {
  try {
    const r = await fetch('/api/book/' + userId);
    const data = await r.json();
    if (data.book) {
      bookTitle = data.book.bookTitle;
      chapters  = data.book.chapters;
      $titleInput.value = bookTitle;
      renderChapters();
      updateStats();
    }
  } catch {}
}

// ── Actions ───────────────────────────────────────────────────────────────────
function setBusy(val) {
  busy = val;
  [$btnGenerate, $btnCritique, $btnSynthesize, $chatSend].forEach(b => b.disabled = val);
  if (!val && publishState === null) $btnPublish.disabled = false;
  showThinking(val);
}

$btnGenerate.onclick = async () => {
  if (busy) return;
  setBusy(true);
  addMessage('System', 'Generating new chapter…');
  try {
    const newContent = await generateChapterAPI(chapters.length);
    const newId = chapters.length + 1;
    const newCh = { id: newId, title: 'Chapter ' + newId, content: newContent };
    chapters.push(newCh);
    selectChapter(newCh);
    renderChapters();
    nudgeStability(8);

    const reply = await callAgent('Muse', newContent, bookTitle);
    addMessage('Muse', reply);
    nudgeStability(4);
    saveBook();
  } catch (e) {
    addMessage('System', 'Error: ' + e.message);
  } finally { setBusy(false); }
};

$btnCritique.onclick = async () => {
  if (busy) return;
  setBusy(true);
  const target = activeChapter || chapters[chapters.length - 1];
  const context = target
    ? '"' + target.title + '": ' + (target.content || '(no content yet)')
    : 'the full manuscript';
  addMessage('System', 'Running critique on ' + (target?.title || 'manuscript') + '…');
  try {
    const criticReply = await callAgent('Critic', context, bookTitle);
    addMessage('Critic', criticReply);
    nudgeStability(-6);

    const others = [...activeAgents].filter(a => a !== 'Critic');
    if (others.length) {
      const pick = others[Math.floor(Math.random() * others.length)];
      const reply = await callAgent(pick, context, bookTitle);
      addMessage(pick, reply);
      nudgeStability(3);
    }
  } catch (e) {
    addMessage('System', 'Error: ' + e.message);
  } finally { setBusy(false); }
};

$btnSynthesize.onclick = async () => {
  if (busy) return;
  setBusy(true);
  addMessage('System', 'Synthesizing chapter…');
  try {
    const { revised, sourceChain } = await synthesizeChapter();
    if (activeChapter && revised) {
      activeChapter.content = revised;
      chapters = chapters.map(c => c.id === activeChapter.id ? activeChapter : c);
      $editorText.value = revised;
      addMessage('System', 'Synthesis complete. ' + (sourceChain?.length || 0) + ' events in provenance chain.');
      saveBook();
    } else if (revised) {
      // No active chapter — suggest adding to last
      addMessage('Sage', revised);
    }
    nudgeStability(12);
  } catch (e) {
    // Fallback
    try {
      const sageReply = await callAgent('Sage', 'Synthesize the current state of the manuscript.', bookTitle);
      addMessage('Sage', sageReply);
      nudgeStability(8);
    } catch (e2) { addMessage('System', 'Error: ' + e2.message); }
  } finally { setBusy(false); }
};

$btnPublish.onclick = async () => {
  if (busy || publishState) return;
  if (bookState === 'PUBLISHED') {
    // Fork instead
    const newId = bookId + '_v' + Date.now().toString(36);
    try {
      const r = await fetch('/api/book/fork', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookId, newBookId: newId })
      });
      const data = await r.json();
      addMessage('System', 'Book is published. New fork created: ' + data.forkedState?.bookId);
    } catch {}
    return;
  }
  publishState = 'exporting';
  $btnPublish.disabled = true;
  $btnPublish.textContent = 'Publishing…';
  $btnPublish.className = 'action-btn publish-exporting';
  try {
    // Transition to PRE_PUBLISH if not already
    if (!['PRE_PUBLISH', 'LOCKED'].includes(bookState)) {
      await fetch('/api/book/transition', {
        method: 'POST', headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ bookId, toState: 'PRE_PUBLISH', reason: 'User publish request' })
      });
      bookState = 'PRE_PUBLISH';
    }
    const r = await fetch('/api/book/publish', {
      method: 'POST', headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ bookId })
    });
    const data = await r.json();
    if (data.ok) {
      bookState = 'PUBLISHED';
      publishState = 'done';
      $btnPublish.textContent = 'Published ✓';
      $btnPublish.className = 'action-btn publish-done';
      $btnPublish.title = 'Click to fork a new version';
      addMessage('System', '"' + bookTitle + '" published. ' + chapters.length + ' chapters · ' + agentTurns + ' agent exchanges.');
      updateStats();
      return;
    }
  } catch {}
  // Fallback: just mark as done locally
  publishState = 'done';
  $btnPublish.textContent = 'Exported ✓';
  $btnPublish.className = 'action-btn publish-done';
  addMessage('System', '"' + bookTitle + '" exported. ' + chapters.length + ' chapters.');
  setTimeout(() => {
    publishState = null;
    $btnPublish.textContent = 'Publish';
    $btnPublish.className = 'action-btn';
    $btnPublish.disabled = false;
  }, 3000);
};

// ── Chat ──────────────────────────────────────────────────────────────────────
async function sendMessage() {
  const text = $chatInput.value.trim();
  if (!text || busy) return;
  $chatInput.value = '';
  addMessage('User', text);
  setBusy(true);
  try {
    const result = await orchestrate(text);

    // Render agent outputs
    if (result.agentOutputs) {
      for (const [agent, reply] of Object.entries(result.agentOutputs)) {
        if (reply) addMessage(agent, reply);
      }
    }

    // Show Art Director guidance if present
    if (result.artDirectorDecision?.direction) {
      addMessage('System', '✦ Art Director: ' + result.artDirectorDecision.direction);
    }

    // Handle loops
    if (result.loops?.length) {
      loopCount += result.loops.length;
      for (const loop of result.loops) {
        if (loop.type === 3) addMessage('System', loop.response || 'What would you like to explore next?');
        if (loop.type === 1 && result.suppressedAgents?.length) {
          addMessage('System', result.suppressedAgents.join(', ') + ': suppressed (loop detected)');
        }
      }
    }

    // Handle DIVERGED
    if (result.state?.state === 'DIVERGED') {
      addMessage('System', '⚡ Divergence detected — Art Director intervened.');
    }

    // Sync stability and state
    if (result.stability !== undefined) { stability = result.stability; renderStability(); }
    if (result.state?.state) { bookState = result.state.state; }
    updateStats();

  } catch (e) {
    // Fallback to simple agent calls if orchestrator fails
    try {
      const target = activeChapter || chapters[chapters.length - 1];
      const context = target ? '"' + target.title + '": ' + (target.content || '') : '';
      for (const agent of activeAgents) {
        const reply = await callAgent(agent, text, context);
        addMessage(agent, reply);
      }
      nudgeStability(5);
    } catch (e2) {
      addMessage('System', 'Error: ' + e2.message);
    }
  } finally { setBusy(false); }
}

$chatSend.onclick = sendMessage;
$chatInput.addEventListener('keydown', e => {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});

// ── Title ─────────────────────────────────────────────────────────────────────
$titleInput.addEventListener('input', () => {
  bookTitle = $titleInput.value || 'Untitled Book';
  saveBook();
});

// ── Init ──────────────────────────────────────────────────────────────────────
async function init() {
  renderAgents();
  renderChapters();
  renderStability();
  updateStats();
  addMessage('Muse',   'The room is open. Bring what you have — even a fragment.');
  addMessage('Critic', 'Readiness is overrated. Begin before you are ready.');
  await loadBook();
  // Load server state
  try {
    const r = await fetch('/api/book/state/' + bookId);
    const d = await r.json();
    if (d.state?.state) {
      bookState = d.state.state;
      stability = d.state.stability || stability;
      renderStability();
      updateStats();
    }
  } catch {}
}
init();
</script>
