<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Room — Nyxa</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:       #070710;
      --surface:  #0e0e1c;
      --surface2: #14142a;
      --border:   rgba(255,255,255,0.07);
      --text:     #e8e8f4;
      --muted:    #5a5a7a;
      --radius:   14px;
      --radius-sm: 8px;
    }

    html, body { height: 100%; background: var(--bg); color: var(--text);
      font-family: 'Segoe UI', system-ui, sans-serif; font-size: 14px;
      line-height: 1.6; overflow: hidden; }

    /* ── Layout ─────────────────────── */
    #app { display: grid; grid-template-columns: 220px 1fr; grid-template-rows: auto 1fr;
      height: 100vh; }

    /* ── Header ─────────────────────── */
    header {
      grid-column: 1 / -1;
      display: flex; align-items: center; gap: 14px;
      padding: 12px 20px;
      background: var(--surface);
      border-bottom: 1px solid var(--border);
      position: relative; z-index: 10;
    }

    .logo { display: flex; align-items: center; gap: 10px; text-decoration: none;
      color: var(--text); font-weight: 700; font-size: 15px; letter-spacing: 0.04em; }

    .logo-mark { width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      background: conic-gradient(from 120deg, #a78bfa, #22d3ee, #fbbf24, #a78bfa);
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 800; color: #fff; }

    .header-center { flex: 1; display: flex; align-items: center; justify-content: center;
      gap: 8px; }

    .room-title { font-size: 14px; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase; color: var(--muted); }

    .room-live { display: flex; align-items: center; gap: 5px; font-size: 11px; color: #4ade80; }
    .live-dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80;
      box-shadow: 0 0 6px #4ade80; animation: blink 2s ease-in-out infinite; }

    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.4} }

    .header-actions { display: flex; gap: 8px; }

    .btn-sm { background: none; border: 1px solid var(--border); color: var(--muted);
      padding: 5px 12px; border-radius: var(--radius-sm); cursor: pointer; font-size: 11px;
      font-family: inherit; transition: all .2s; white-space: nowrap; }
    .btn-sm:hover { border-color: rgba(255,255,255,.2); color: var(--text); }

    /* ── Voice Settings Panel ─────────── */
    .vp-overlay { position: fixed; inset: 0; background: rgba(0,0,0,.5); z-index: 50;
      opacity: 0; pointer-events: none; transition: opacity .25s; }
    .vp-overlay.open { opacity: 1; pointer-events: all; }

    .vp-panel { position: fixed; top: 0; right: 0; bottom: 0; width: 360px; max-width: 95vw;
      background: var(--surface); border-left: 1px solid var(--border);
      z-index: 51; display: flex; flex-direction: column;
      transform: translateX(100%); transition: transform .3s cubic-bezier(.4,0,.2,1);
      overflow: hidden; }
    .vp-panel.open { transform: translateX(0); }

    .vp-header { display: flex; align-items: center; justify-content: space-between;
      padding: 16px 20px; border-bottom: 1px solid var(--border); flex-shrink: 0; }
    .vp-header h2 { font-size: 14px; font-weight: 600; letter-spacing: .04em; }
    .vp-close { background: none; border: none; color: var(--muted); font-size: 18px;
      cursor: pointer; padding: 2px 6px; border-radius: 6px; transition: color .2s; }
    .vp-close:hover { color: var(--text); }

    .vp-body { flex: 1; overflow-y: auto; padding: 16px 20px; display: flex;
      flex-direction: column; gap: 20px; }
    .vp-body::-webkit-scrollbar { width: 3px; }
    .vp-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .vp-section-title { font-size: 10px; text-transform: uppercase; letter-spacing: .08em;
      color: var(--muted); margin-bottom: 10px; }

    .vp-stt-row { display: flex; align-items: center; gap: 10px; }
    .vp-stt-row label { font-size: 12px; color: var(--muted); min-width: 60px; }
    .vp-stt-row select { flex: 1; background: var(--surface2); border: 1px solid var(--border);
      color: var(--text); padding: 6px 10px; border-radius: var(--radius-sm);
      font-size: 12px; font-family: inherit; outline: none; cursor: pointer; }

    .vp-agent-row { background: var(--surface2); border: 1px solid var(--border);
      border-radius: var(--radius); overflow: hidden; margin-bottom: 10px; }

    .vp-agent-hd { display: flex; align-items: center; gap: 10px; padding: 10px 14px;
      border-bottom: 1px solid var(--border);
      background: color-mix(in srgb, var(--ac) 6%, transparent); }
    .vp-agent-av { width: 28px; height: 28px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700;
      background: color-mix(in srgb, var(--ac) 18%, transparent);
      border: 1px solid var(--ac); color: var(--ac); flex-shrink: 0; }
    .vp-agent-name { font-size: 13px; font-weight: 600; flex: 1; }
    .btn-test { background: none; border: 1px solid var(--border); color: var(--muted);
      padding: 3px 10px; border-radius: 6px; font-size: 11px; cursor: pointer;
      transition: all .2s; }
    .btn-test:hover { border-color: var(--ac); color: var(--ac); }

    .vp-controls { padding: 10px 14px; display: flex; flex-direction: column; gap: 8px; }
    .vc-row { display: flex; align-items: center; gap: 8px; }
    .vc-row label { font-size: 11px; color: var(--muted); min-width: 48px;
      display: flex; justify-content: space-between; }
    .vc-row label span { color: var(--text); font-variant-numeric: tabular-nums; }
    .vc-row select { flex: 1; background: var(--bg); border: 1px solid var(--border);
      color: var(--text); padding: 5px 8px; border-radius: 6px; font-size: 11px;
      font-family: inherit; outline: none; cursor: pointer; }
    .vc-row input[type=range] { flex: 1; -webkit-appearance: none; height: 3px;
      border-radius: 2px; background: var(--border); outline: none; cursor: pointer; }
    .vc-row input[type=range]::-webkit-slider-thumb { -webkit-appearance: none;
      width: 12px; height: 12px; border-radius: 50%; background: var(--ac); cursor: pointer; }

    .vp-footer { padding: 14px 20px; border-top: 1px solid var(--border);
      display: flex; gap: 8px; flex-shrink: 0; }
    .vp-footer button { flex: 1; background: none; border: 1px solid var(--border);
      color: var(--muted); padding: 7px; border-radius: var(--radius-sm); font-size: 12px;
      font-family: inherit; cursor: pointer; transition: all .2s; }
    .vp-footer button:hover { border-color: rgba(255,255,255,.2); color: var(--text); }

    /* ── Mic recording indicator ──────── */
    .mic-live { display: none; align-items: center; gap: 6px; font-size: 11px; color: #f87171; }
    .mic-live.on { display: flex; }
    .mic-live-dot { width: 6px; height: 6px; border-radius: 50%; background: #f87171;
      animation: blink 0.8s ease-in-out infinite; }

    /* ── Sidebar ─────────────────────── */
    aside {
      background: var(--surface);
      border-right: 1px solid var(--border);
      overflow-y: auto;
      padding: 16px 12px;
      display: flex; flex-direction: column; gap: 6px;
    }

    aside::-webkit-scrollbar { width: 3px; }
    aside::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .sidebar-label { font-size: 10px; text-transform: uppercase; letter-spacing: .08em;
      color: var(--muted); padding: 2px 8px 8px; }

    .agent-chip {
      display: flex; align-items: center; gap: 9px;
      padding: 8px 10px;
      border-radius: var(--radius-sm);
      border: 1px solid transparent;
      transition: all .2s; cursor: default;
    }

    .agent-chip.active { background: var(--surface2); border-color: var(--border); }
    .agent-chip.speaking { border-color: var(--agent-color) !important;
      box-shadow: 0 0 10px color-mix(in srgb, var(--agent-color) 20%, transparent); }

    .chip-avatar {
      width: 30px; height: 30px; border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 12px; font-weight: 700;
      background: color-mix(in srgb, var(--agent-color) 18%, transparent);
      border: 1px solid var(--agent-color);
      color: var(--agent-color);
      flex-shrink: 0;
      transition: box-shadow .3s;
    }

    .agent-chip.speaking .chip-avatar {
      box-shadow: 0 0 14px color-mix(in srgb, var(--agent-color) 45%, transparent);
      animation: chip-pulse 1.2s ease-in-out infinite;
    }

    @keyframes chip-pulse {
      0%,100% { box-shadow: 0 0 8px color-mix(in srgb, var(--agent-color) 30%, transparent); }
      50% { box-shadow: 0 0 20px color-mix(in srgb, var(--agent-color) 60%, transparent); }
    }

    .chip-info { min-width: 0; }
    .chip-name { font-size: 12px; font-weight: 600; color: var(--text); }
    .chip-type { font-size: 10px; color: var(--muted); }

    .chip-status { margin-left: auto; width: 6px; height: 6px; border-radius: 50%;
      background: #4ade80; flex-shrink: 0; }

    .divider { height: 1px; background: var(--border); margin: 8px 0; }

    .human-chip { display: flex; align-items: center; gap: 9px; padding: 8px 10px;
      border-radius: var(--radius-sm); background: var(--surface2);
      border: 1px solid var(--border); }
    .human-avatar { width: 30px; height: 30px; border-radius: 50%;
      background: rgba(232,232,244,.1); border: 1px solid rgba(232,232,244,.2);
      display: flex; align-items: center; justify-content: center; font-size: 14px; }
    .human-name { font-size: 12px; font-weight: 600; }
    .human-role { font-size: 10px; color: var(--muted); }

    /* ── Main Chat ───────────────────── */
    main { display: flex; flex-direction: column; overflow: hidden; }

    .messages {
      flex: 1; overflow-y: auto;
      padding: 20px 24px;
      display: flex; flex-direction: column; gap: 0;
      scroll-behavior: smooth;
    }

    .messages::-webkit-scrollbar { width: 4px; }
    .messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    /* ── Message ─────────────────────── */
    .msg-group {
      display: flex; flex-direction: column;
      margin-bottom: 18px;
      animation: msg-in .3s ease-out;
    }

    @keyframes msg-in { from{opacity:0;transform:translateY(10px)} to{opacity:1;transform:translateY(0)} }

    .msg-group.user { align-items: flex-end; }
    .msg-group.agent { align-items: flex-start; }

    .msg-header {
      display: flex; align-items: center; gap: 7px;
      margin-bottom: 5px; padding: 0 4px;
    }

    .msg-group.user .msg-header { flex-direction: row-reverse; }

    .msg-avatar {
      width: 28px; height: 28px; border-radius: 50%; flex-shrink: 0;
      display: flex; align-items: center; justify-content: center;
      font-size: 11px; font-weight: 700;
    }

    .msg-name { font-size: 11px; font-weight: 600; }
    .msg-time { font-size: 10px; color: var(--muted); }

    .msg-bubble {
      max-width: 72%;
      padding: 11px 15px;
      border-radius: var(--radius);
      font-size: 13.5px; line-height: 1.6;
      position: relative;
    }

    .msg-group.user .msg-bubble {
      background: rgba(232,232,244,.08);
      border: 1px solid rgba(232,232,244,.12);
      border-radius: var(--radius) var(--radius) 4px var(--radius);
      color: var(--text);
    }

    .msg-group.agent .msg-bubble {
      border-radius: var(--radius) var(--radius) var(--radius) 4px;
    }

    /* ── Routing badge ───────────────── */
    .routing-badge {
      align-self: center;
      display: flex; align-items: center; gap: 6px;
      padding: 5px 12px;
      background: var(--surface2);
      border: 1px solid var(--border);
      border-radius: 20px;
      font-size: 11px; color: var(--muted);
      margin: 4px 0 10px;
      animation: msg-in .3s ease-out;
    }

    .routing-badge .agent-pills { display: flex; gap: 4px; flex-wrap: wrap; }
    .routing-pill {
      padding: 2px 8px; border-radius: 10px; font-size: 10px; font-weight: 600;
      background: color-mix(in srgb, var(--pc) 18%, transparent);
      color: var(--pc);
      border: 1px solid color-mix(in srgb, var(--pc) 35%, transparent);
    }

    /* ── Typing indicator ────────────── */
    .typing-row {
      display: flex; align-items: center; gap: 8px;
      padding: 6px 4px;
      animation: msg-in .2s ease-out;
    }

    .typing-agent { font-size: 11px; color: var(--muted); }

    .typing-dots { display: flex; gap: 3px; align-items: center; }
    .typing-dots span { width: 5px; height: 5px; border-radius: 50%;
      background: var(--dot-color); opacity: 0.5;
      animation: tdot 1.2s ease-in-out infinite; }
    .typing-dots span:nth-child(2) { animation-delay: .2s; }
    .typing-dots span:nth-child(3) { animation-delay: .4s; }
    @keyframes tdot { 0%,80%,100%{transform:translateY(0);opacity:.3} 40%{transform:translateY(-5px);opacity:1} }

    .empty-room {
      flex: 1; display: flex; flex-direction: column; align-items: center;
      justify-content: center; gap: 14px; color: var(--muted); text-align: center;
      padding: 40px;
    }

    .empty-orb { width: 80px; height: 80px; border-radius: 50%;
      background: conic-gradient(from 0deg, rgba(167,139,250,.15), rgba(34,211,238,.15), rgba(251,191,36,.15), rgba(167,139,250,.15));
      display: flex; align-items: center; justify-content: center; font-size: 32px; opacity: .4;
      animation: spin 20s linear infinite; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* ── Input ───────────────────────── */
    .input-area {
      border-top: 1px solid var(--border);
      background: var(--surface);
      padding: 14px 20px;
      display: flex; flex-direction: column; gap: 10px;
    }

    .orchestrator-hint {
      font-size: 11px; color: var(--muted);
      display: flex; align-items: center; gap: 6px;
    }

    .hint-orb { width: 8px; height: 8px; border-radius: 50%;
      background: conic-gradient(#a78bfa, #22d3ee, #fbbf24, #a78bfa);
      animation: spin 4s linear infinite; flex-shrink: 0; }

    .input-row { display: flex; align-items: flex-end; gap: 8px; }

    textarea {
      flex: 1; background: var(--surface2); border: 1px solid var(--border);
      border-radius: var(--radius); color: var(--text); padding: 10px 14px;
      font-size: 13.5px; font-family: inherit; line-height: 1.5; resize: none;
      max-height: 120px; min-height: 42px; outline: none;
      transition: border-color .2s, box-shadow .2s;
    }

    textarea:focus { border-color: rgba(167,139,250,.5);
      box-shadow: 0 0 0 3px rgba(167,139,250,.07); }
    textarea::placeholder { color: var(--muted); }

    .btn-icon { width: 40px; height: 40px; border-radius: var(--radius-sm);
      border: 1px solid var(--border); background: var(--surface2); color: var(--muted);
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      font-size: 16px; transition: all .2s; flex-shrink: 0; }
    .btn-icon:hover { border-color: rgba(255,255,255,.2); color: var(--text); }
    .btn-icon:disabled { opacity: .4; cursor: not-allowed; }

    .btn-send { width: 40px; height: 40px; border-radius: var(--radius-sm);
      border: none; background: linear-gradient(135deg, #a78bfa, #60a5fa);
      color: #fff; cursor: pointer; display: flex; align-items: center;
      justify-content: center; font-size: 16px; transition: all .2s; flex-shrink: 0;
      box-shadow: 0 2px 12px rgba(167,139,250,.3); }
    .btn-send:hover { filter: brightness(1.1); transform: scale(1.04); }
    .btn-send:disabled { opacity: .4; cursor: not-allowed; transform: none; }

    .btn-voice.recording { background: #dc2626 !important; border-color: #dc2626 !important;
      color: #fff !important; animation: pulse-rec 1s ease-in-out infinite; }
    @keyframes pulse-rec { 0%,100%{box-shadow:0 0 0 0 rgba(220,38,38,.4)} 50%{box-shadow:0 0 0 6px rgba(220,38,38,0)} }

    .voice-row { display: flex; align-items: center; gap: 12px; }

    .voice-toggle { display: flex; align-items: center; gap: 6px; cursor: pointer;
      user-select: none; color: var(--muted); font-size: 11px; }
    .voice-toggle input { display: none; }
    .toggle-pill { width: 28px; height: 15px; border-radius: 8px; background: var(--surface2);
      border: 1px solid var(--border); position: relative; transition: all .2s; }
    .toggle-pill::after { content:''; width: 9px; height: 9px; border-radius: 50%;
      background: var(--muted); position: absolute; top: 2px; left: 2px; transition: all .2s; }
    .voice-toggle input:checked + .toggle-pill { background: rgba(167,139,250,.25); border-color: #a78bfa; }
    .voice-toggle input:checked + .toggle-pill::after { transform: translateX(13px); background: #a78bfa; }

    .user-name-input { background: var(--surface2); border: 1px solid var(--border);
      border-radius: var(--radius-sm); color: var(--text); padding: 5px 10px;
      font-size: 12px; font-family: inherit; outline: none; width: 110px;
      transition: border-color .2s; }
    .user-name-input:focus { border-color: rgba(255,255,255,.2); }

    /* ── Back link ───────────────────── */
    .back-link { font-size: 11px; color: var(--muted); text-decoration: none;
      display: flex; align-items: center; gap: 4px; transition: color .2s; }
    .back-link:hover { color: var(--text); }

    /* ── Mobile ──────────────────────── */
    @media (max-width: 640px) {
      #app { grid-template-columns: 1fr; }
      aside { display: none; }
    }
  </style>
</head>
<body>
<div id="app">
  <header>
    <a href="/dashboard/" class="back-link">← Chat</a>
    <a href="/dashboard/" class="logo">
      <div class="logo-mark">N</div>
    </a>
    <div class="header-center">
      <span class="room-title">The Room</span>
      <div class="room-live"><div class="live-dot"></div> live</div>
    </div>
    <div class="header-actions">
      <button class="btn-sm" onclick="openVoiceSettings()">⚙ Voices</button>
      <button class="btn-sm" onclick="clearRoom()">Clear</button>
    </div>
  </header>

  <!-- Voice Settings Panel -->
  <div class="vp-overlay" id="vpOverlay" onclick="closeVoiceSettings()"></div>
  <div class="vp-panel" id="vpPanel">
    <div class="vp-header">
      <h2>Voice Settings</h2>
      <button class="vp-close" onclick="closeVoiceSettings()">✕</button>
    </div>
    <div class="vp-body">
      <div>
        <div class="vp-section-title">Your Microphone</div>
        <div class="vp-stt-row">
          <label>Language</label>
          <select id="sttLangSelect" onchange="saveSttLang()">
            <option value="en-US">English (US)</option>
            <option value="en-GB">English (UK)</option>
            <option value="de-DE">Deutsch</option>
            <option value="fr-FR">Français</option>
            <option value="es-ES">Español</option>
            <option value="it-IT">Italiano</option>
            <option value="pt-BR">Português (BR)</option>
            <option value="ja-JP">日本語</option>
            <option value="zh-CN">中文 (简体)</option>
          </select>
        </div>
      </div>
      <div>
        <div class="vp-section-title">TTS Provider</div>
        <div class="vp-stt-row">
          <label>Engine</label>
          <select id="ttsProviderSel" onchange="saveTtsProvider()" style="flex:1;background:var(--bg);border:1px solid var(--border);color:var(--text);padding:6px 10px;border-radius:var(--radius-sm);font-size:12px;font-family:inherit;outline:none;cursor:pointer;">
            <option value="browser">Browser (Web Speech)</option>
            <option value="elevenlabs">ElevenLabs (HD)</option>
          </select>
        </div>
      </div>
      <div>
        <div class="vp-section-title">Agent Voices</div>
        <div id="vpAgentList"></div>
      </div>
    </div>
    <div class="vp-footer">
      <button onclick="testAllVoices()">▶ Test All</button>
      <button onclick="resetAllVoices()">↺ Reset Defaults</button>
    </div>
  </div>

  <aside id="sidebar">
    <div class="sidebar-label">Participants</div>

    <div class="human-chip">
      <div class="human-avatar">👤</div>
      <div>
        <div class="human-name" id="humanNameDisplay">You</div>
        <div class="human-role">Human</div>
      </div>
    </div>

    <div class="divider"></div>
    <div class="sidebar-label">Agents</div>
    <div id="agentList"></div>
  <div class="divider" style="margin-top:auto;"></div>
  <div style="padding:8px 10px;">
    <div class="sidebar-label" style="padding:0 0 6px;">Guest Agent</div>
    <div class="agent-chip active" style="--agent-color:#c084fc;flex-direction:column;align-items:flex-start;gap:6px;cursor:pointer;" onclick="document.getElementById('saraWidget').style.display=document.getElementById('saraWidget').style.display==='none'?'flex':'none'">
      <div style="display:flex;align-items:center;gap:9px;width:100%;">
        <div class="chip-avatar" style="background:color-mix(in srgb,#c084fc 18%,transparent);border:1px solid #c084fc;color:#c084fc;">♪</div>
        <div class="chip-info">
          <div class="chip-name" style="color:#c084fc;">Sara la Kali</div>
          <div class="chip-type">ConvAI · ElevenLabs</div>
        </div>
        <div class="chip-status" style="background:#c084fc;box-shadow:0 0 6px #c084fc;"></div>
      </div>
    </div>
  </div>
  </aside>

  <main>
    <div class="messages" id="messages">
      <div class="empty-room" id="emptyState">
        <div class="empty-orb">✦</div>
        <div style="font-size:15px;font-weight:600;">The Room is open.</div>
        <div style="font-size:12px;max-width:280px;">
          Send a message. The Orchestrator will decide which agents respond.<br>
          Agents can hear each other and build on each other's replies.
        </div>
      </div>
    </div>

    <div class="input-area">
      <div class="orchestrator-hint">
        <div class="hint-orb"></div>
        Orchestrator active — routing to best agents automatically
      </div>
      <div class="input-row">
        <textarea id="msgInput" placeholder="Say something to the room…" rows="1"
          onkeydown="onKey(event)" oninput="autoResize(this)"></textarea>
        <button class="btn-icon btn-voice" id="micBtn" title="Click to record"
          onclick="toggleVoice()">🎙</button>
        <button class="btn-send" id="sendBtn" onclick="send()">➤</button>
      </div>
      <div class="voice-row">
        <div class="mic-live" id="micLive">
          <div class="mic-live-dot"></div> listening…
        </div>
        <label class="voice-toggle" title="Read agent responses aloud">
          <input type="checkbox" id="ttsToggle" />
          <div class="toggle-pill"></div>
          Voice replies
        </label>
        <span style="color:var(--muted);font-size:11px;">Your name:</span>
        <input type="text" class="user-name-input" id="userNameInput" value="Johannes"
          placeholder="Your name" oninput="updateHumanName()" />
      </div>
    </div>
  </main>
</div>

<script>
'use strict';

const API = window.location.origin;
let busy  = false;

// ── Agent registry ─────────────────────────────────────────────────────────────

let AGENTS = {};

async function loadAgents() {
  try {
    const res  = await fetch(API + '/api/room/agents');
    const data = await res.json();
    if (data.ok) {
      data.agents.forEach(a => { AGENTS[a.key] = a; });
      renderSidebar();
    }
  } catch {}
}

function renderSidebar() {
  const list = document.getElementById('agentList');
  list.innerHTML = '';
  Object.values(AGENTS).forEach(a => {
    const el = document.createElement('div');
    el.className = 'agent-chip';
    el.id = 'chip-' + a.key;
    el.style.setProperty('--agent-color', a.color);
    el.innerHTML = `
      <div class="chip-avatar">${a.emoji}</div>
      <div class="chip-info">
        <div class="chip-name">${a.name}</div>
        <div class="chip-type">${a.type}</div>
      </div>
      <div class="chip-status"></div>`;
    list.appendChild(el);
  });
}

function setAgentSpeaking(key, on) {
  const chip = document.getElementById('chip-' + key);
  if (chip) chip.classList.toggle('speaking', on);
}

function updateHumanName() {
  const val = document.getElementById('userNameInput')?.value || 'You';
  const el  = document.getElementById('humanNameDisplay');
  if (el) el.textContent = val;
}

// ── Voice Settings (localStorage) ─────────────────────────────────────────────

const LS_VOICES = 'nyxa_voice_settings_v2';
const LS_STT    = 'nyxa_stt_lang';

const VOICE_DEFAULTS = {
  sophia:    { female: true,  pitch: 1.10, rate: 0.93 },
  mentor:    { female: false, pitch: 0.95, rate: 1.05 },
  runner:    { female: false, pitch: 0.90, rate: 1.10 },
  oracle:    { female: false, pitch: 1.00, rate: 0.87 },
  archivist: { female: false, pitch: 0.92, rate: 0.92 },
  codex:     { female: false, pitch: 1.00, rate: 1.00 },
  nyxadev:   { female: false, pitch: 0.87, rate: 1.10 },
};

let voiceSettings = {};
let sttLang = 'en-US';

function loadVoiceSettings() {
  try { const s = localStorage.getItem(LS_VOICES); if (s) voiceSettings = JSON.parse(s); } catch {}
  try { sttLang = localStorage.getItem(LS_STT) || 'en-US'; } catch {}
  const sel = document.getElementById('sttLangSelect');
  if (sel) sel.value = sttLang;
}

function saveVoiceSettings() {
  try { localStorage.setItem(LS_VOICES, JSON.stringify(voiceSettings)); } catch {}
}

function saveSttLang() {
  sttLang = document.getElementById('sttLangSelect')?.value || 'en-US';
  try { localStorage.setItem(LS_STT, sttLang); } catch {}
}

function allVoices() {
  return ('speechSynthesis' in window) ? speechSynthesis.getVoices() : [];
}

function getAgentVoice(agentKey) {
  const savedName = voiceSettings[agentKey]?.voiceName;
  if (savedName) {
    const v = allVoices().find(v => v.name === savedName);
    if (v) return v;
  }
  // Auto-assign based on defaults
  const def   = VOICE_DEFAULTS[agentKey] || {};
  const all   = allVoices();
  const enAll = all.filter(v => /en/i.test(v.lang));
  const pool  = def.female
    ? (enAll.filter(v => /samantha|karen|victoria|zira|female|fiona|moira/i.test(v.name)).length
        ? enAll.filter(v => /samantha|karen|victoria|zira|female|fiona|moira/i.test(v.name))
        : enAll)
    : (enAll.filter(v => /daniel|alex|david|mark|oliver|george|fred/i.test(v.name)).length
        ? enAll.filter(v => /daniel|alex|david|mark|oliver|george|fred/i.test(v.name))
        : enAll);
  const keys = Object.keys(VOICE_DEFAULTS);
  const idx  = keys.indexOf(agentKey);
  return pool[idx % Math.max(pool.length, 1)] || all[0] || null;
}

function getAgentPitch(agentKey) {
  return voiceSettings[agentKey]?.pitch ?? VOICE_DEFAULTS[agentKey]?.pitch ?? 1.0;
}

function getAgentRate(agentKey) {
  return voiceSettings[agentKey]?.rate ?? VOICE_DEFAULTS[agentKey]?.rate ?? 1.0;
}

if ('speechSynthesis' in window) {
  speechSynthesis.onvoiceschanged = () => {
    if (document.getElementById('vpPanel')?.classList.contains('open')) renderVoicePanel();
  };
}

// TTS Queue (sequential, no cancel between agents)
const ttsQueue = [];
let ttsSpeaking = false;

const LS_TTS_PROVIDER = 'nyxa_tts_provider';
let ttsProvider = 'browser';
(function() { try { ttsProvider = localStorage.getItem(LS_TTS_PROVIDER) || 'browser'; } catch {} })();

function saveTtsProvider() {
  ttsProvider = document.getElementById('ttsProviderSel')?.value || 'browser';
  try { localStorage.setItem(LS_TTS_PROVIDER, ttsProvider); } catch {}
}

function loadTtsProvider() {
  const sel = document.getElementById('ttsProviderSel');
  if (sel) sel.value = ttsProvider;
}

function speakMsg(agentKey, text) {
  if (!document.getElementById('ttsToggle')?.checked) return;
  ttsQueue.push({ agentKey, text });
  if (!ttsSpeaking) drainTtsQueue();
}

function drainTtsQueue() {
  if (!ttsQueue.length) { ttsSpeaking = false; return; }
  ttsSpeaking = true;
  const { agentKey, text } = ttsQueue.shift();

  if (ttsProvider === 'elevenlabs') {
    const agent = AGENTS[agentKey];
    const voiceId = agent?.elevenLabsVoiceId;
    if (!voiceId) { setAgentSpeaking(agentKey, false); drainTtsQueue(); return; }
    setAgentSpeaking(agentKey, true);
    fetch(API + '/api/tts', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ text, voiceId })
    })
    .then(r => r.ok ? r.arrayBuffer() : Promise.reject(r.status))
    .then(buf => {
      const blob = new Blob([buf], { type: 'audio/mpeg' });
      const url  = URL.createObjectURL(blob);
      const audio = new Audio(url);
      audio.onended = audio.onerror = () => {
        URL.revokeObjectURL(url);
        setAgentSpeaking(agentKey, false);
        drainTtsQueue();
      };
      audio.play().catch(() => { setAgentSpeaking(agentKey, false); drainTtsQueue(); });
    })
    .catch(() => { setAgentSpeaking(agentKey, false); drainTtsQueue(); });
    return;
  }

  // Browser TTS fallback
  if (!('speechSynthesis' in window)) { drainTtsQueue(); return; }
  const voice = getAgentVoice(agentKey);
  const clean = text.replace(/[*_`#~]/g, '').replace(/
+/g, '. ');
  const utt   = new SpeechSynthesisUtterance(clean);
  utt.pitch   = getAgentPitch(agentKey);
  utt.rate    = getAgentRate(agentKey);
  if (voice) utt.voice = voice;
  utt.onstart = () => setAgentSpeaking(agentKey, true);
  utt.onend = utt.onerror = () => {
    setAgentSpeaking(agentKey, false);
    drainTtsQueue();
  };
  speechSynthesis.speak(utt);
}text) {
  if (!document.getElementById('ttsToggle')?.checked) return;
  if (!('speechSynthesis' in window)) return;
  ttsQueue.push({ agentKey, text });
  if (!ttsSpeaking) drainTtsQueue();
}

function drainTtsQueue() {
  if (!ttsQueue.length) { ttsSpeaking = false; return; }
  ttsSpeaking = true;
  const { agentKey, text } = ttsQueue.shift();
  const voice = getAgentVoice(agentKey);
  const clean = text.replace(/[*_`#~]/g, '').replace(/\n+/g, '. ');
  const utt   = new SpeechSynthesisUtterance(clean);
  utt.pitch   = getAgentPitch(agentKey);
  utt.rate    = getAgentRate(agentKey);
  if (voice) utt.voice = voice;
  utt.onstart = () => setAgentSpeaking(agentKey, true);
  utt.onend = utt.onerror = () => {
    setAgentSpeaking(agentKey, false);
    drainTtsQueue();
  };
  speechSynthesis.speak(utt);
}

function clearTtsQueue() {
  ttsQueue.length = 0;
  ttsSpeaking = false;
  speechSynthesis.cancel();
}

// ── Voice Settings Panel ───────────────────────────────────────────────────────

function openVoiceSettings() {
  renderVoicePanel();
  document.getElementById('vpPanel')?.classList.add('open');
  document.getElementById('vpOverlay')?.classList.add('open');
}

function closeVoiceSettings() {
  document.getElementById('vpPanel')?.classList.remove('open');
  document.getElementById('vpOverlay')?.classList.remove('open');
}

function renderVoicePanel() {
  const sttSel = document.getElementById('sttLangSelect');
  if (sttSel) sttSel.value = sttLang;

  const list = document.getElementById('vpAgentList');
  if (!list) return;
  list.innerHTML = '';

  const available = allVoices();
  const options   = ['<option value="">— Auto —</option>',
    ...available.map(v => `<option value="${esc(v.name)}">${esc(v.name)} (${v.lang})</option>`)
  ].join('');

  Object.values(AGENTS).forEach(agent => {
    const k     = agent.key;
    const saved = voiceSettings[k] || {};
    const pitch = saved.pitch ?? VOICE_DEFAULTS[k]?.pitch ?? 1.0;
    const rate  = saved.rate  ?? VOICE_DEFAULTS[k]?.rate  ?? 1.0;

    const row = document.createElement('div');
    row.className = 'vp-agent-row';
    row.innerHTML = `
      <div class="vp-agent-hd" style="--ac:${agent.color}">
        <div class="vp-agent-av">${agent.emoji}</div>
        <div class="vp-agent-name">${agent.name}</div>
        <button class="btn-test" onclick="testAgentVoice('${k}')">▶ Test</button>
      </div>
      <div class="vp-controls">
        <div class="vc-row">
          <label>Voice</label>
          <select id="vsel-${k}" onchange="onVoiceChange('${k}')" style="--ac:${agent.color}">${options}</select>
        </div>
        <div class="vc-row">
          <label>Pitch <span id="vplbl-${k}">${pitch.toFixed(2)}</span></label>
          <input type="range" id="vpitch-${k}" min="0.5" max="2" step="0.05" value="${pitch}"
            oninput="onPitchChange('${k}',this.value)" style="--ac:${agent.color}" />
        </div>
        <div class="vc-row">
          <label>Speed <span id="vrlbl-${k}">${rate.toFixed(2)}</span></label>
          <input type="range" id="vrate-${k}" min="0.5" max="2" step="0.05" value="${rate}"
            oninput="onRateChange('${k}',this.value)" style="--ac:${agent.color}" />
        </div>
      </div>`;
    list.appendChild(row);

    const sel = document.getElementById('vsel-' + k);
    if (sel && saved.voiceName) sel.value = saved.voiceName;
  });
}

function onVoiceChange(k) {
  if (!voiceSettings[k]) voiceSettings[k] = {};
  voiceSettings[k].voiceName = document.getElementById('vsel-' + k)?.value || '';
  saveVoiceSettings();
}

function onPitchChange(k, val) {
  const v = parseFloat(val);
  if (!voiceSettings[k]) voiceSettings[k] = {};
  voiceSettings[k].pitch = v;
  const lbl = document.getElementById('vplbl-' + k);
  if (lbl) lbl.textContent = v.toFixed(2);
  saveVoiceSettings();
}

function onRateChange(k, val) {
  const v = parseFloat(val);
  if (!voiceSettings[k]) voiceSettings[k] = {};
  voiceSettings[k].rate = v;
  const lbl = document.getElementById('vrlbl-' + k);
  if (lbl) lbl.textContent = v.toFixed(2);
  saveVoiceSettings();
}

function testAgentVoice(k) {
  const agent = AGENTS[k];
  if (!agent || !('speechSynthesis' in window)) return;
  speechSynthesis.cancel();
  const utt = new SpeechSynthesisUtterance(`Hello, I am ${agent.name}.`);
  utt.pitch = getAgentPitch(k);
  utt.rate  = getAgentRate(k);
  const v   = getAgentVoice(k);
  if (v) utt.voice = v;
  speechSynthesis.speak(utt);
}

function testAllVoices() {
  const keys = Object.keys(AGENTS);
  let i = 0;
  function next() {
    if (i >= keys.length) return;
    const k   = keys[i++];
    const a   = AGENTS[k];
    const utt = new SpeechSynthesisUtterance(`${a.name}.`);
    utt.pitch = getAgentPitch(k); utt.rate = getAgentRate(k);
    const v   = getAgentVoice(k); if (v) utt.voice = v;
    utt.onend = next;
    speechSynthesis.speak(utt);
  }
  speechSynthesis.cancel();
  next();
}

function resetAllVoices() {
  voiceSettings = {};
  saveVoiceSettings();
  renderVoicePanel();
}

// ── Speech-to-Text (toggle mode) ───────────────────────────────────────────────

const SpeechRec = window.SpeechRecognition || window.webkitSpeechRecognition;
let recognition     = null;
let isListening     = false;
let finalTranscript = '';
let prefixText      = '';

function toggleVoice() {
  if (!SpeechRec) { alert('Speech recognition is not supported in this browser. Try Chrome or Edge.'); return; }
  isListening ? stopListening() : startListening();
}

function startListening() {
  isListening     = true;
  finalTranscript = '';
  const inp       = document.getElementById('msgInput');
  prefixText      = inp?.value || '';

  document.getElementById('micBtn')?.classList.add('recording');
  document.getElementById('micLive')?.classList.add('on');

  recognition = new SpeechRec();
  recognition.lang           = sttLang;
  recognition.interimResults = true;
  recognition.continuous     = true;

  recognition.onresult = (e) => {
    let interim = '';
    for (let i = e.resultIndex; i < e.results.length; i++) {
      e.results[i].isFinal
        ? (finalTranscript += e.results[i][0].transcript + ' ')
        : (interim += e.results[i][0].transcript);
    }
    const inp = document.getElementById('msgInput');
    if (inp) { inp.value = prefixText + finalTranscript + interim; autoResize(inp); }
  };

  recognition.onerror = (e) => { if (e.error !== 'aborted') stopListening(); };
  recognition.onend   = () => { if (isListening) { try { recognition.start(); } catch { stopListening(); } } };
  recognition.start();
}

function stopListening() {
  isListening = false;
  if (recognition) { try { recognition.stop(); } catch {} recognition = null; }
  document.getElementById('micBtn')?.classList.remove('recording');
  document.getElementById('micLive')?.classList.remove('on');
  // Keep only finalized text
  const inp = document.getElementById('msgInput');
  if (inp) { inp.value = (prefixText + finalTranscript).trimEnd(); autoResize(inp); }
  prefixText = ''; finalTranscript = '';
}

// ── Send & render ─────────────────────────────────────────────────────────────

function onKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); }
}

function autoResize(el) {
  el.style.height = 'auto';
  el.style.height = Math.min(el.scrollHeight, 120) + 'px';
}

async function send() {
  if (busy) return;
  const inp     = document.getElementById('msgInput');
  const message = inp?.value.trim();
  if (!message) return;

  const userName = document.getElementById('userNameInput')?.value.trim() || 'You';

  inp.value = '';
  autoResize(inp);
  removeEmpty();

  addUserMsg(userName, message);
  setBusy(true);

  // Show orchestrator thinking
  const routingId = addRouting(null);

  try {
    const res  = await fetch(API + '/api/room/message', {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify({ message, userName })
    });
    const data = await res.json();

    updateRouting(routingId, data.chosenAgents || []);

    if (data.ok && data.responses?.length) {
      for (let i = 0; i < data.responses.length; i++) {
        const r = data.responses[i];
        await delay(i === 0 ? 200 : 600);
        addAgentMsg(r);
        if (document.getElementById('ttsToggle')?.checked) {
          await delay(200);
          speakMsg(r.agentKey, r.message);
        }
      }
    } else if (data.error) {
      addErrorMsg(data.error);
    }
  } catch (err) {
    updateRouting(routingId, []);
    addErrorMsg('Could not reach API: ' + err.message);
  }

  setBusy(false);
}

function delay(ms) { return new Promise(r => setTimeout(r, ms)); }

function setBusy(on) {
  busy = on;
  document.getElementById('sendBtn')?.toggleAttribute('disabled', on);
  document.getElementById('msgInput')?.toggleAttribute('disabled', on);
}

function removeEmpty() {
  document.getElementById('emptyState')?.remove();
}

function scrollBottom() {
  const el = document.getElementById('messages');
  if (el) el.scrollTop = el.scrollHeight;
}

function fmtTime(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
}

function esc(s) {
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

function addUserMsg(name, text) {
  const msgs = document.getElementById('messages');
  const g = document.createElement('div');
  g.className = 'msg-group user';
  g.innerHTML = `
    <div class="msg-header">
      <div class="msg-avatar" style="background:rgba(232,232,244,.1);border:1px solid rgba(232,232,244,.2);">👤</div>
      <span class="msg-name" style="color:#e8e8f4;">${esc(name)}</span>
      <span class="msg-time">${fmtTime(new Date().toISOString())}</span>
    </div>
    <div class="msg-bubble">${esc(text).replace(/\n/g,'<br>')}</div>`;
  msgs.appendChild(g);
  scrollBottom();
}

function addRouting(agents) {
  const msgs = document.getElementById('messages');
  const id   = 'routing-' + Math.random().toString(36).slice(2);
  const el   = document.createElement('div');
  el.className = 'routing-badge';
  el.id = id;
  el.innerHTML = `<div class="hint-orb"></div> <span>Orchestrator routing…</span>`;
  msgs.appendChild(el);
  scrollBottom();
  return id;
}

function updateRouting(id, agentKeys) {
  const el = document.getElementById(id);
  if (!el) return;
  if (!agentKeys?.length) { el.remove(); return; }
  const pills = agentKeys.map(k => {
    const a = AGENTS[k];
    if (!a) return '';
    return `<span class="routing-pill" style="--pc:${a.color}">${a.name}</span>`;
  }).join('');
  el.innerHTML = `<span style="color:var(--muted)">→</span> <div class="agent-pills">${pills}</div>`;
  scrollBottom();
}

function addAgentMsg(entry) {
  const a    = AGENTS[entry.agentKey] || { color: '#aaa', emoji: '?' };
  const msgs = document.getElementById('messages');
  const g    = document.createElement('div');
  g.className = 'msg-group agent';
  g.innerHTML = `
    <div class="msg-header">
      <div class="msg-avatar" style="
        background:color-mix(in srgb,${a.color} 18%,transparent);
        border:1.5px solid ${a.color};color:${a.color};font-weight:700;font-size:11px;"
      >${a.emoji}</div>
      <span class="msg-name" style="color:${a.color};">${esc(entry.agent)}</span>
      <span class="msg-time">${fmtTime(entry.timestamp)}</span>
    </div>
    <div class="msg-bubble" style="
      background:color-mix(in srgb,${a.color} 8%,var(--surface2));
      border:1px solid color-mix(in srgb,${a.color} 20%,transparent);"
    >${esc(entry.message).replace(/\n/g,'<br>')}</div>`;
  msgs.appendChild(g);
  scrollBottom();
}

function addErrorMsg(text) {
  const msgs = document.getElementById('messages');
  const g    = document.createElement('div');
  g.className = 'msg-group agent';
  g.innerHTML = `
    <div class="msg-header">
      <div class="msg-avatar" style="background:rgba(248,113,113,.1);border:1px solid #f87171;color:#f87171;">!</div>
      <span class="msg-name" style="color:#f87171;">Error</span>
    </div>
    <div class="msg-bubble" style="background:rgba(248,113,113,.07);border:1px solid rgba(248,113,113,.2);">${esc(text)}</div>`;
  msgs.appendChild(g);
  scrollBottom();
}

async function clearRoom() {
  await fetch(API + '/api/room/clear', { method: 'DELETE' });
  const msgs = document.getElementById('messages');
  msgs.innerHTML = `
    <div class="empty-room" id="emptyState">
      <div class="empty-orb">✦</div>
      <div style="font-size:15px;font-weight:600;">The Room is open.</div>
      <div style="font-size:12px;max-width:280px;">Send a message. The Orchestrator will decide which agents respond.</div>
    </div>`;
  clearTtsQueue();
}

// ── Load history on page load ──────────────────────────────────────────────────

async function loadHistory() {
  try {
    const res  = await fetch(API + '/api/room/history');
    const data = await res.json();
    if (data.ok && data.history?.length) {
      removeEmpty();
      data.history.forEach(entry => {
        if (entry.role === 'user') addUserMsg(entry.agent, entry.message);
        else addAgentMsg(entry);
      });
    }
  } catch {}
}

// ── Init ──────────────────────────────────────────────────────────────────────

loadVoiceSettings();
loadTtsProvider();
loadAgents().then(a => { renderVoicePanel && renderVoicePanel(); loadHistory(); });

if (!SpeechRec) {
  const btn = document.getElementById('micBtn');
  if (btn) { btn.disabled = true; btn.title = 'Not supported in this browser (use Chrome/Edge)'; }
}
</script>

<!-- Sara la Kali ConvAI Widget -->
<div id="saraWidget" style="display:none;position:fixed;bottom:80px;right:20px;width:360px;max-width:95vw;flex-direction:column;z-index:40;background:#0e0e1c;border:1px solid rgba(192,132,252,.3);border-radius:14px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.5);">
  <div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:rgba(192,132,252,.08);border-bottom:1px solid rgba(192,132,252,.15);">
    <div style="display:flex;align-items:center;gap:10px;">
      <div style="width:28px;height:28px;border-radius:50%;background:rgba(192,132,252,.18);border:1px solid #c084fc;color:#c084fc;display:flex;align-items:center;justify-content:center;font-size:14px;">♪</div>
      <div>
        <div style="font-size:13px;font-weight:600;color:#c084fc;">Sara la Kali</div>
        <div style="font-size:10px;color:#5a5a7a;">Flamenco Soul · ElevenLabs ConvAI</div>
      </div>
    </div>
    <button onclick="document.getElementById('saraWidget').style.display='none'" style="background:none;border:none;color:#5a5a7a;font-size:16px;cursor:pointer;">✕</button>
  </div>
  <div style="padding:16px;display:flex;flex-direction:column;align-items:center;gap:12px;">
    <elevenlabs-convai agent-id="agent_7301k11vaxqmfqsv9e192ry5dsay"></elevenlabs-convai>
    <div style="font-size:11px;color:#5a5a7a;text-align:center;">Click the orb to speak with Sara la Kali</div>
  </div>
</div>
<script src="https://unpkg.com/@elevenlabs/convai-widget-embed" async type="text/javascript"></script>
</body>
</html>
